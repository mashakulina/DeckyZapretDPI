{
  "name": "decky-zapretdpi",
  "version": "1.0.0",
  "description": "Decky plugin for Zapret DPI Manager — service toggle and status",
  "scripts": {
    "build": "shx rm -rf dist && rollup -c",
    "watch": "rollup -c -w"
  },
  "keywords": ["decky", "plugin", "zapret", "steam-deck"],
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^21.1.0",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-node-resolve": "^13.3.0",
    "@rollup/plugin-replace": "^4.0.0",
    "@rollup/plugin-typescript": "^8.5.0",
    "@types/react": "16.14.0",
    "rollup": "^2.79.2",
    "rollup-plugin-import-assets": "^1.1.1",
    "shx": "^0.3.4",
    "tslib": "^2.8.1",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "decky-frontend-lib": "^3.25.0",
    "react-icons": "^4.12.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": ["react", "react-dom"]
    }
  }
}
